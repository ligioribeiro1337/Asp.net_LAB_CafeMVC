@model IEnumerable<Order>
@{
    ViewData["Title"] = "Заказы";
}
<h2>Заказы</h2>
<p><a asp-action="Create" class="btn btn-primary">+ Новый заказ</a></p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Номер</th>
            <th>Блюда</th>
            <th>Время</th>
            <th>Статус</th>
            <th>Сеть кафе</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.OrderNumber</td>
                <td>@item.Dishes</td>
                <td>@item.OrderTime.ToString("g")</td>
                <td>
                    @{
                        var badgeClass = item.Status switch
                        {
                            "Новый" => "bg-primary",
                            "Готовится" => "bg-warning text-dark",
                            "Выполнен" => "bg-success",
                            "Отменён" => "bg-danger",
                            _ => "bg-secondary"
                        };
                    }
                    <span class="badge @badgeClass">@item.Status</span>
                </td>
                <td>@item.CafeChain?.Name</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>
