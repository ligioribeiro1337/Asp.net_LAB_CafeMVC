@model IEnumerable<CafeChain>
@{
    ViewData["Title"] = "Сети кафе";
}
<h2>Сети кафе</h2>
<p><a asp-action="Create" class="btn btn-primary">+ Добавить</a></p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Название</th>
            <th>Тип кухни</th>
            <th>Регионы</th>
            <th>Меню</th>
            <th>Год</th>
            <th>Заказов</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.CuisineType</td>
                <td>@item.Regions</td>
                <td>@item.Menu</td>
                <td>@item.FoundedYear</td>
                <td>@(item.Orders?.Count ?? 0)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>
